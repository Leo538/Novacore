PORT=3000
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Cloudinary: para que el sistema suba fotos desde el dispositivo y guarde la URL en la BD
# Crear cuenta gratis en https://cloudinary.com y copiar desde Dashboard > API Keys
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
